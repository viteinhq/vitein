  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260421.1",
    "@vitein/config": "workspace:*",
    "@vitein/openapi-spec": "workspace:*",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "wrangler": "^4.84.1",
    "yaml": "^2.6.1"
