    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sentry/cloudflare": "^9.46.0",
    "hono": "^4.6.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241112.0",
    "@vitein/config": "workspace:*",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "wrangler": "^3.87.0"
  }
}
