{
  "name": "@vitein/api",
  "version": "0.0.0",
  "private": true,
  "description": "vite.in Core API — Cloudflare Worker + Hono",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production",
