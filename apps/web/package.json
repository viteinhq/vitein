{
  "name": "@vitein/web",
  "version": "0.0.0",
  "private": true,
  "description": "vite.in web client — SvelteKit on Cloudflare Pages",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "sync": "svelte-kit sync",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "lint": "pnpm paraglide:compile && svelte-kit sync && eslint src",
    "typecheck": "pnpm paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "pnpm paraglide:compile && vitest run"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@inlang/paraglide-sveltekit": "^0.16.1",
    "@vitein/ts-sdk": "workspace:*"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^1.11.8",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@vitein/config": "workspace:*",
    "eslint-plugin-svelte": "^2.46.0",
    "svelte": "^5.15.0",
    "svelte-check": "^4.1.1",
    "svelte-eslint-parser": "^0.43.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.5",
    "wrangler": "^4.84.1"
  }
}
