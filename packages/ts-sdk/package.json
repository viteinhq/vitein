{
  "name": "@vitein/ts-sdk",
  "version": "0.0.0",
  "private": true,
  "description": "Auto-generated TypeScript SDK for the vite.in API. Do not edit by hand.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "generate": "openapi-ts",
    "generate:check": "openapi-ts && git diff --exit-code src/generated",
    "lint": "eslint src --ignore-pattern 'src/generated/**'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.96.0",
    "@vitein/config": "workspace:*",
    "@vitein/openapi-spec": "workspace:*",
    "typescript": "^5.6.3"
  }
}
